# Optional: structured logging (all Go binaries — see .agent/epics/phase_1/logging/epic_P1_logging.md)
# LOG_LEVEL=info
# APP_VERSION=dev

# Database
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=changeme
POSTGRES_DB=portfolio
DATABASE_URL=postgres://portfolio:changeme@db:5432/portfolio?sslmode=disable

# Broker selection
BROKER_PROVIDER=ibkr
BROKER_ENV=paper

# IBKR (used when BROKER_PROVIDER=ibkr; use IBKR_MODE=paper or live when a real gateway is available)
IBKR_GATEWAY_HOST=ib-gateway
IBKR_GATEWAY_PORT=4001
IBKR_MODE=mock


# Coinbase (used when BROKER_PROVIDER=coinbase)
COINBASE_READ_API_KEY=
COINBASE_READ_API_SECRET=
COINBASE_TRADE_API_KEY=
COINBASE_TRADE_API_SECRET=

# Trading rollout controls (portfolio-api / trading-worker)
TRADING_ENABLED=false
TRADING_KILL_SWITCH=false
TRADING_MAX_NOTIONAL=1000
TRADING_RESERVE=0
TRADING_ALLOWED_PROVIDERS=coinbase
TRADING_ALLOWED_SYMBOLS=BTC-USD,ETH-USD
TRADING_DENIED_SYMBOLS=

# Auth (portfolio-api)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
AUTH_SECRET=changeme-32-char-min

# Internal API (ingest/signals → portfolio-api; required — portfolio-api refuses empty)
INTERNAL_API_KEY=changeme

# Ingest
INGEST_INTERVAL=10m
PORTFOLIO_API_URL=http://portfolio-api:8080

# Signals
SIGNAL_RULES_PATH=./config/signals.yaml
SIGNAL_COOLDOWN=1h
SIGNAL_INTERVAL=5m
SIGNAL_DEDUP_PATH=./data/signal-dedup.json

# IBKR Client Portal (paper/live; optional)
IBKR_CLIENT_PORTAL_PORT=5000

# Discord
DISCORD_WEBHOOK_URL=
# Optional: raw Discord mention so a bot sees pings (e.g. "<@123456789012345678>" from Developer Mode → Copy User ID)
DISCORD_SIGNAL_BOT_MENTION=

# portfolio-api: origins allowed for *direct* browser calls to :8080 (only if you set NEXT_PUBLIC_API_URL)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Web (Next.js): server-side rewrite target for /api-go → portfolio-api (Docker Compose default below)
PORTFOLIO_API_INTERNAL_URL=http://portfolio-api:8080

# Optional: if set, browser calls this URL instead of same-origin /api-go (then CORS + NEXT_PUBLIC must match your LAN)
# NEXT_PUBLIC_API_URL=
