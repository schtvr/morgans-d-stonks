# Database
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=changeme
POSTGRES_DB=portfolio
DATABASE_URL=postgres://portfolio:changeme@db:5432/portfolio?sslmode=disable

# IBKR
IBKR_GATEWAY_HOST=ib-gateway
IBKR_GATEWAY_PORT=4001
IBKR_MODE=paper

# Auth (portfolio-api)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
AUTH_SECRET=changeme-32-char-min

# Internal API (ingest → portfolio-api)
INTERNAL_API_KEY=changeme

# Ingest
INGEST_INTERVAL=10m
PORTFOLIO_API_URL=http://portfolio-api:8080

# Signals
SIGNAL_RULES_PATH=./config/signals.yaml
SIGNAL_COOLDOWN=1h
SIGNAL_INTERVAL=5m
SIGNAL_DEDUP_PATH=./data/signal-dedup.json

# IBKR Client Portal (paper/live; optional)
IBKR_CLIENT_PORTAL_PORT=5000

# Discord
DISCORD_WEBHOOK_URL=

# Web
NEXT_PUBLIC_API_URL=http://localhost:8080
